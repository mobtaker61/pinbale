{
  "name": "@pinbale/worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --out-dir dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@pinbale/cache": "*",
    "@pinbale/config": "*",
    "@pinbale/observability": "*",
    "@pinbale/providers": "*",
    "@pinbale/queue": "*"
  }
}
