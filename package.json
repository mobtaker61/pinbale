{
  "name": "pinbale",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade Bale bot backend for Pinterest search",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev": "npm run dev -w @pinbale/api",
    "dev:worker": "npm run dev -w @pinbale/worker",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p apps/api/tsconfig.json && tsc --noEmit -p apps/worker/tsconfig.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.0.9"
  },
  "dependencies": {
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.2",
    "bullmq": "^5.46.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.2.2",
    "ioredis": "^5.5.0",
    "pino": "^9.6.0",
    "playwright": "^1.51.1",
    "undici": "^7.5.0",
    "zod": "^3.24.2"
  }
}
