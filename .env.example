NODE_ENV=development
PORT=3000
LOG_LEVEL=info

REDIS_URL=redis://redis:6379

# حداقل یکی از بله یا تلگرام الزامی است
BALE_BOT_TOKEN=your_bale_token
BALE_WEBHOOK_SECRET=
BALE_API_BASE_URL=https://tapi.bale.ai/bot

# ربات تلگرام (اختیاری) — وب‌هوک: POST /webhooks/telegram یا همان /webhooks/bale
# اگر بله و تلگرام با هم فعال‌اند و هر دو به /webhooks/bale می‌خورند، حتماً secret_token در setWebhook تلگرام = TELEGRAM_WEBHOOK_SECRET
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_API_BASE_URL=https://api.telegram.org/bot
# آدرس پایهٔ عمومی همین API (بدون / در انتها) — همان دامنهٔ وب‌هوک/تونل؛ برای ارسال تصویر به بله با لینک الزامی است
PUBLIC_BASE_URL=

PINTEREST_PROVIDER_MODE=hybrid
PINTEREST_API_BASE_URL=
PINTEREST_ACCESS_TOKEN=

PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_NAV_TIMEOUT_MS=15000
PLAYWRIGHT_ACTION_TIMEOUT_MS=8000
PLAYWRIGHT_MAX_CONTEXTS=4
PLAYWRIGHT_PROXY_SERVER=
PLAYWRIGHT_PROXY_USERNAME=
PLAYWRIGHT_PROXY_PASSWORD=
PLAYWRIGHT_USER_AGENT=

SEARCH_RESULTS_PER_PAGE=5
SEARCH_RESULTS_MAX=20
SEARCH_CACHE_TTL_SEC=900
SESSION_TTL_SEC=3600
NEGATIVE_CACHE_TTL_SEC=120

RATE_LIMIT_PER_USER_PER_MIN=15
RATE_LIMIT_PER_IP_PER_MIN=60
QUEUE_GLOBAL_RATE_LIMIT_MAX=100
QUEUE_GLOBAL_RATE_LIMIT_DURATION_MS=60000

ADMIN_TOKEN=change_this_token
# محدودیت کاربر؛ برای بله و تلگرام جدا: ALLOWLIST_BALE_USER_IDS و ALLOWLIST_TELEGRAM_USER_IDS
ALLOWLIST_USER_IDS=
ALLOWLIST_BALE_USER_IDS=
ALLOWLIST_TELEGRAM_USER_IDS=
BANNED_KEYWORDS=

# آرشیو تصاویر محلی (/list) — مسیر نسبت به cwd فرآیند api/worker
LOCAL_IMAGES_DIR=images
LOCAL_IMAGES_PER_REQUEST=10

# حداکثر پست اینستاگرام برای هر دستور /instagram یا /ig (۱ تا ۲۰، پیش‌فرض ۹)
INSTAGRAM_MAX_POSTS=9
# اگر INSTAGRAM_RAPIDAPI_KEY مقدار داشته باشد، پست‌ها فقط از RapidAPI گرفته می‌شود (پایدارتر از اسکرپ مستقیم).
# مسیر و هاست را از بخش «Code Snippets» همان API که subscribe کرده‌اید کپی کنید (پیش‌فرض برای instagram120 است).
# INSTAGRAM_RAPIDAPI_KEY=your_rapidapi_key
# INSTAGRAM_RAPIDAPI_HOST=instagram120.p.rapidapi.com
# INSTAGRAM_RAPIDAPI_POSTS_PATH=/api/instagram/posts
# INSTAGRAM_RAPIDAPI_HTTP_METHOD=POST
# INSTAGRAM_RAPIDAPI_TIMEOUT_MS=60000
# اگر API بدنه را فقط با username می‌خواهد false بگذارید؛ اگر به count نیاز دارد true
# INSTAGRAM_RAPIDAPI_POST_INCLUDE_COUNT=false
# همان maxId اسنیپت RapidAPI (صفحه بعد؛ اولین بار خالی بماند)
# INSTAGRAM_RAPIDAPI_POST_MAX_ID=
# پیش‌فرض true: عکس معمولاً با URL؛ ویدیو اول روی worker دانلود سپس فایل (تلگرام اغلب URL ویدیوی IG را 400 می‌کند). false = همه را مثل قبل فقط دانلود روی worker
# INSTAGRAM_RAPIDAPI_MESSENGER_FETCH_MEDIA=true
# اختیاری: کوکی‌های مرورگر بعد از ورود به instagram.com (DevTools → Application → Cookies)
# INSTAGRAM_SESSION_ID=
# INSTAGRAM_CSRF_TOKEN=
# پروکسی HTTP CONNECT (نه لینک تونل خام): http://USER:PASS@HOST:PORT — کاراکترهای خاص در رمز را encode کنید
# هم برای اسکرپ و هم برای دانلود مدیا از fbcdn وقتی RapidAPI فعال است (بدون آن روی دیتاسنتر اغلب fetch failed)
# INSTAGRAM_HTTPS_PROXY=http://user:secret@home.example.com:3128
# حداکثر تلاش برای web_profile_info بعد از ۴۲۹ (۱ تا ۱۲، پیش‌فرض ۵)
# INSTAGRAM_WEB_RETRY_MAX=5
# پایهٔ تأخیر بین تلاش‌ها (میلی‌ثانیه)
# INSTAGRAM_WEB_RETRY_BASE_MS=5000
